<?xml version="1.0" encoding="utf-8"?>
<!--
    AndroidManifest.xml — MapApplication
    Declares all components, permissions, and security settings
    required to run this mapping app on Android 7.0+
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
        LOCATION PERMISSIONS
        ┌─ ACCESS_FINE_LOCATION   → GPS-grade accuracy (~5 m)
        └─ ACCESS_COARSE_LOCATION → Network/WiFi-based accuracy (~100 m)
        Both are declared; the app will request the appropriate one at runtime.
    -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!--
        READ_PHONE_STATE
        Historically used to retrieve the IMEI as a device identifier.
        We declare it here for compatibility; we will use a privacy-safe
        alternative (Settings.Secure.ANDROID_ID) in the actual code.
    -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />

    <!--
        INTERNET
        Required for:
          • Downloading OSM map tiles from the tile server
          • Sending location data to our backend API
    -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MapApplication"
        tools:targetApi="31">

        <!-- Secondary screen: Google Maps viewer (not exported — internal use only) -->
        <activity
            android:name=".GoogleMapActivity"
            android:exported="false" />

        <!-- Entry point of the application -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

    </application>

</manifest>